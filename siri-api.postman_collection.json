{
  "info": {
    "name": "Siri API",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "base_url", "value": "https://duniakarya.store/api" },
    { "key": "token_user", "value": "" },
    { "key": "token_driver", "value": "" },
    { "key": "token_admin", "value": "" },
    { "key": "store_id", "value": "" },
    { "key": "food_item_id", "value": "" },
    { "key": "order_id", "value": "" },
    { "key": "service_id", "value": "" },
    { "key": "section_id", "value": "" },
    { "key": "section_item_id", "value": "" }
  ],
  "item": [
    {
      "name": "Auth",
      "item": [
        {
          "name": "Register",
          "request": {
            "method": "POST",
            "header": [{ "key": "Accept", "value": "application/json" }],
            "url": { "raw": "{{base_url}}/register", "host": ["{{base_url}}"], "path": ["register"] },
            "body": {
              "mode": "raw",
              "options": { "raw": { "language": "json" } },
              "raw": "{\n  \"name\": \"John Doe\",\n  \"email\": \"john@example.com\",\n  \"phone\": \"081200000099\",\n  \"password\": \"password\",\n  \"password_confirmation\": \"password\",\n  \"role\": \"user\"\n}"
            }
          }
        },
        {
          "name": "Login (User)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "var res = pm.response.json();",
                  "if (res.data && res.data.token) {",
                  "  pm.collectionVariables.set('token_user', res.data.token);",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Accept", "value": "application/json" }],
            "url": { "raw": "{{base_url}}/login", "host": ["{{base_url}}"], "path": ["login"] },
            "body": {
              "mode": "raw",
              "options": { "raw": { "language": "json" } },
              "raw": "{\n  \"identifier\": \"user@siri.id\",\n  \"password\": \"password\"\n}"
            }
          }
        },
        {
          "name": "Login (Driver)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "var res = pm.response.json();",
                  "if (res.data && res.data.token) {",
                  "  pm.collectionVariables.set('token_driver', res.data.token);",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Accept", "value": "application/json" }],
            "url": { "raw": "{{base_url}}/login", "host": ["{{base_url}}"], "path": ["login"] },
            "body": {
              "mode": "raw",
              "options": { "raw": { "language": "json" } },
              "raw": "{\n  \"identifier\": \"driver@siri.id\",\n  \"password\": \"password\"\n}"
            }
          }
        },
        {
          "name": "Login (Admin)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "var res = pm.response.json();",
                  "if (res.data && res.data.token) {",
                  "  pm.collectionVariables.set('token_admin', res.data.token);",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Accept", "value": "application/json" }],
            "url": { "raw": "{{base_url}}/login", "host": ["{{base_url}}"], "path": ["login"] },
            "body": {
              "mode": "raw",
              "options": { "raw": { "language": "json" } },
              "raw": "{\n  \"identifier\": \"admin@siri.id\",\n  \"password\": \"password\"\n}"
            }
          }
        },
        {
          "name": "Logout",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Accept", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token_user}}" }
            ],
            "url": { "raw": "{{base_url}}/logout", "host": ["{{base_url}}"], "path": ["logout"] }
          }
        }
      ]
    },
    {
      "name": "Public",
      "item": [
        {
          "name": "Home Sections",
          "request": {
            "method": "GET",
            "header": [{ "key": "Accept", "value": "application/json" }],
            "url": { "raw": "{{base_url}}/home", "host": ["{{base_url}}"], "path": ["home"] }
          }
        },
        {
          "name": "List Stores",
          "request": {
            "method": "GET",
            "header": [{ "key": "Accept", "value": "application/json" }],
            "url": { "raw": "{{base_url}}/stores", "host": ["{{base_url}}"], "path": ["stores"] }
          }
        },
        {
          "name": "Get Store Detail",
          "request": {
            "method": "GET",
            "header": [{ "key": "Accept", "value": "application/json" }],
            "url": { "raw": "{{base_url}}/stores/{{store_id}}", "host": ["{{base_url}}"], "path": ["stores", "{{store_id}}"] }
          }
        },
        {
          "name": "Get Store Food Items",
          "request": {
            "method": "GET",
            "header": [{ "key": "Accept", "value": "application/json" }],
            "url": { "raw": "{{base_url}}/stores/{{store_id}}/foods", "host": ["{{base_url}}"], "path": ["stores", "{{store_id}}", "foods"] }
          }
        },
        {
          "name": "List Foods",
          "request": {
            "method": "GET",
            "header": [{ "key": "Accept", "value": "application/json" }],
            "url": { "raw": "{{base_url}}/foods", "host": ["{{base_url}}"], "path": ["foods"] }
          }
        },
        {
          "name": "Get Food Item Detail",
          "request": {
            "method": "GET",
            "header": [{ "key": "Accept", "value": "application/json" }],
            "url": { "raw": "{{base_url}}/foods/{{food_item_id}}", "host": ["{{base_url}}"], "path": ["foods", "{{food_item_id}}"] }
          }
        },
        {
          "name": "Search",
          "request": {
            "method": "GET",
            "header": [{ "key": "Accept", "value": "application/json" }],
            "url": {
              "raw": "{{base_url}}/search?q=nasi",
              "host": ["{{base_url}}"],
              "path": ["search"],
              "query": [{ "key": "q", "value": "nasi" }]
            }
          }
        },
        {
          "name": "List Services",
          "request": {
            "method": "GET",
            "header": [{ "key": "Accept", "value": "application/json" }],
            "url": { "raw": "{{base_url}}/services", "host": ["{{base_url}}"], "path": ["services"] }
          }
        }
      ]
    },
    {
      "name": "Profile",
      "item": [
        {
          "name": "Get Profile",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Accept", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token_user}}" }
            ],
            "url": { "raw": "{{base_url}}/profile", "host": ["{{base_url}}"], "path": ["profile"] }
          }
        },
        {
          "name": "Update Profile",
          "request": {
            "method": "PUT",
            "header": [
              { "key": "Accept", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token_user}}" }
            ],
            "url": { "raw": "{{base_url}}/profile/update", "host": ["{{base_url}}"], "path": ["profile", "update"] },
            "body": {
              "mode": "raw",
              "options": { "raw": { "language": "json" } },
              "raw": "{\n  \"name\": \"User Demo Updated\",\n  \"phone\": \"081200000099\",\n  \"address\": \"Jl. Thamrin No. 10, Jakarta Pusat\",\n  \"latitude\": -6.1944,\n  \"longitude\": 106.8229\n}"
            }
          }
        }
      ]
    },
    {
      "name": "Orders",
      "item": [
        {
          "name": "Create Order (Ride/Service)",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Accept", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token_user}}" }
            ],
            "url": { "raw": "{{base_url}}/orders", "host": ["{{base_url}}"], "path": ["orders"] },
            "body": {
              "mode": "raw",
              "options": { "raw": { "language": "json" } },
              "raw": "{\n  \"service_id\": \"{{service_id}}\",\n  \"pickup_location\": \"Jl. Sudirman No. 5, Jakarta Pusat\",\n  \"destination_location\": \"Jl. Gatot Subroto No. 20, Jakarta Selatan\",\n  \"price\": 25000,\n  \"notes\": \"Tolong cepat ya\"\n}"
            }
          }
        },
        {
          "name": "Create Food Order",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Accept", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token_user}}" }
            ],
